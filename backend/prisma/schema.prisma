generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id               String   @id @default(cuid())
  kratosIdentityId String   @unique
  email            String   @unique
  isVerified       Boolean  @default(false)
  firstName        String?
  lastName         String?
  role             UserRole @default(USER)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
