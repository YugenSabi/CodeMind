generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

enum FileLanguage {
  PLAINTEXT
  JAVASCRIPT
  TYPESCRIPT
  PYTHON
  JSON
  HTML
  CSS
  MARKDOWN
}

enum FileEventType {
  FILE_CREATED
  FILE_UPDATED
  FILE_DELETED
  FILE_OPENED
  FILE_COLLABORATION_JOINED
  FILE_COLLABORATION_LEFT
  FILE_SNAPSHOT_STORED
}

enum RoomMode {
  JUST_CODING
  INTERVIEWS
  ALGORITHMS
}

enum RoomAiInteractionKind {
  CURSOR_COMPLETE
  SELECTION_EXPLAIN
  SELECTION_REVIEW
  SELECTION_IMPROVE
  GENERATE_FROM_INSTRUCTION
  ALGORITHM_TASK_GENERATED
  ALGORITHM_SOLUTION_REVIEWED
}

enum AlgorithmDifficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id               String        @id @default(cuid())
  kratosIdentityId String        @unique
  email            String        @unique
  isVerified       Boolean       @default(false)
  firstName        String?
  lastName         String?
  avatarUrl        String?
  role             UserRole      @default(USER)
  files            ProjectFile[]
  fileEvents       FileEvent[]
  ownedRooms       Room[]        @relation("RoomOwner")
  rooms            Room[]        @relation("RoomMembers")
  aiInteractions   RoomAiInteraction[]
  generatedTasks   RoomAlgorithmTask[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Room {
  id        String        @id @default(cuid())
  name      String
  joinCode  String        @unique
  mode      RoomMode      @default(JUST_CODING)
  ownerId   String
  owner     User          @relation("RoomOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  users     User[]        @relation("RoomMembers")
  directories ProjectDirectory[]
  files     ProjectFile[]
  aiInteractions RoomAiInteraction[]
  algorithmTasks RoomAlgorithmTask[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([ownerId])
}

model ProjectDirectory {
  id        String             @id @default(cuid())
  roomId    String
  parentId  String?
  name      String
  room      Room               @relation(fields: [roomId], references: [id], onDelete: Cascade)
  parent    ProjectDirectory?  @relation("DirectoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children  ProjectDirectory[] @relation("DirectoryChildren")
  files     ProjectFile[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([roomId])
  @@index([parentId])
}

model ProjectFile {
  id        String        @id @default(cuid())
  roomId    String?
  directoryId String?
  ownerId   String
  name      String
  path      String?
  language  FileLanguage  @default(PLAINTEXT)
  owner     User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  directory ProjectDirectory? @relation(fields: [directoryId], references: [id], onDelete: SetNull)
  room      Room?         @relation(fields: [roomId], references: [id], onDelete: SetNull)
  snapshot  FileSnapshot?
  events    FileEvent[]
  aiInteractions RoomAiInteraction[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([roomId])
  @@index([directoryId])
  @@index([ownerId])
}

model FileSnapshot {
  id        String      @id @default(cuid())
  fileId    String      @unique
  file      ProjectFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  state     Bytes
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model FileEvent {
  id        String        @id @default(cuid())
  fileId    String
  actorId   String?
  type      FileEventType
  payload   Json?
  file      ProjectFile   @relation(fields: [fileId], references: [id], onDelete: Cascade)
  actor     User?         @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt DateTime      @default(now())

  @@index([fileId, createdAt])
  @@index([actorId])
}

model RoomAiInteraction {
  id        String                @id @default(cuid())
  roomId    String
  fileId    String?
  actorId   String?
  kind      RoomAiInteractionKind
  prompt    String
  response  String
  metadata  Json?
  room      Room                  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  file      ProjectFile?          @relation(fields: [fileId], references: [id], onDelete: SetNull)
  actor     User?                 @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt DateTime              @default(now())

  @@index([roomId, createdAt])
  @@index([fileId])
  @@index([actorId])
}

model RoomAlgorithmTask {
  id                 String               @id @default(cuid())
  roomId              String
  createdById         String?
  difficulty          AlgorithmDifficulty
  title               String
  problemStatement    String
  inputFormat         String?
  outputFormat        String?
  constraints         String?
  starterCode         String?
  examples            Json?
  hints               Json?
  evaluationCriteria  String?
  isActive            Boolean              @default(true)
  room                Room                 @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdBy           User?                @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([roomId, isActive])
  @@index([createdById])
}
